# ============================================================================
# ScopePilot Test Fixture — synthetic HTTP server for integration tests
# Uses a minimal Alpine-based Go build.
# ============================================================================
FROM docker.io/library/golang:1.26-alpine@sha256:5e5e60ea14e48d2039718813f156ed8ceaf1cee274d9930bde91dcb8cfd90103 AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

# Copy only what's needed
COPY containers/fixture/main.go ./containers/fixture/main.go

ARG TARGETARCH=arm64
RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH} \
    go build \
      -buildvcs=false \
      -ldflags="-s -w -extldflags=-static" \
      -o /fixture \
      ./containers/fixture/

# ============================================================================
# Runtime stage — tiny Alpine
# ============================================================================
FROM alpine:3.21

RUN apk add --no-cache ca-certificates && \
    adduser -D -u 10001 -h /nonexistent -s /sbin/nologin scopepilot

COPY --from=builder /fixture /fixture

USER 10001

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:8080/health || exit 1

ENTRYPOINT ["/fixture"]
